GEOMETRYCOLLECTION	XY	10000000

# geosilo_metadata on invalid blob
statement error
SELECT geosilo_metadata('\x00\x01\x02\x03'::BLOB);
----
GeoSilo: invalid blob

# ---------------------------------------------------------------------------
# More empty geometry types
# ---------------------------------------------------------------------------

query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTIPOINT EMPTY'))));
----
MULTIPOINT EMPTY

query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTILINESTRING EMPTY'))));
----
MULTILINESTRING EMPTY

query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('GEOMETRYCOLLECTION EMPTY'))));
