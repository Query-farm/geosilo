# ---------------------------------------------------------------------------
# Negative coordinates
# ---------------------------------------------------------------------------

query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT(-180 -90)'))));
----
POINT (-180 -90)

query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('LINESTRING(-180 -90, -170 -80, -160 -70)'))));
----
LINESTRING (-180 -90, -170 -80, -160 -70)

# ---------------------------------------------------------------------------
# Many vertices — verifies delta chain doesn't accumulate errors
# ---------------------------------------------------------------------------

# Generate a linestring with 100 points: (0,0), (1,0), (2,0), ..., (99,0)
query I
SELECT ST_NPoints(geosilo_decode(geosilo_encode(
    ST_MakeLine(list(ST_Point(i, 0)))
))) FROM range(100) t(i);
----
100

# Verify first and last coordinates survive roundtrip
query II
SELECT ST_X(ST_PointN(decoded, 1)), ST_X(ST_PointN(decoded, 100))
FROM (
    SELECT geosilo_decode(geosilo_encode(
        ST_MakeLine(list(ST_Point(i, 0)))
    )) AS decoded FROM range(100) t(i)
);
----
0.0	99.0

# ---------------------------------------------------------------------------
# Variable-width delta encoding — int16 vs int32 escape
# ---------------------------------------------------------------------------

# Small deltas should produce a smaller blob than large deltas
# Nearby points: deltas fit in int16 (2 bytes each)
# Far points: deltas need int32 escape (6 bytes each)
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText('LINESTRING(0 0, 0.001 0.001, 0.002 0.002)')))
     < octet_length(geosilo_encode(ST_GeomFromText('LINESTRING(0 0, 100 100, -100 -100)')));
----
true

# ---------------------------------------------------------------------------
# Batch processing — encode/decode over multiple rows
# ---------------------------------------------------------------------------

query I
SELECT count(*) FROM (
    SELECT geosilo_decode(geosilo_encode(ST_Point(i * 0.01, i * 0.02))) AS geom
    FROM range(1000) t(i)
) WHERE round(ST_X(geom), 2) = round(ST_Y(geom) / 2, 2);
----
1000

# ---------------------------------------------------------------------------
# NULL in batch — NULLs should pass through without affecting other rows
# ---------------------------------------------------------------------------

query I
SELECT count(*) FROM (
    SELECT geosilo_decode(geosilo_encode(CASE WHEN i % 3 = 0 THEN NULL ELSE ST_Point(i, i) END)) AS geom
    FROM range(9) t(i)
) WHERE geom IS NULL;
----
3

query I
SELECT count(*) FROM (
    SELECT geosilo_decode(geosilo_encode(CASE WHEN i % 3 = 0 THEN NULL ELSE ST_Point(i, i) END)) AS geom
    FROM range(9) t(i)
) WHERE geom IS NOT NULL;
----
6

# ---------------------------------------------------------------------------
# geosilo_metadata NULL in batch
# ---------------------------------------------------------------------------

query I
SELECT geosilo_metadata(NULL::BLOB) IS NULL;
----
true

# ---------------------------------------------------------------------------
# Invalid input
# ---------------------------------------------------------------------------

# Random blob (invalid magic) should fail
statement error
SELECT geosilo_decode('\x00\x01\x02\x03'::BLOB);
----
GeoSilo: invalid magic byte

# Truncated blob (too small for header)
statement error
SELECT geosilo_decode('\x47\x01'::BLOB);
----
GeoSilo: blob too small

# Wrong version byte
statement error
SELECT geosilo_decode('\x47\xFF\x01\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00'::BLOB);
----
GeoSilo: unsupported version

# ---------------------------------------------------------------------------
# Scale auto-detection from CRS
# ---------------------------------------------------------------------------

# WGS84 CRS → scale 1e7
statement ok
CREATE TABLE t_wgs AS SELECT ST_SetCRS(ST_GeomFromText('POINT(1 2)'), 'EPSG:4326') AS geom;

query I
SELECT (geosilo_metadata(geosilo_encode(geom))).scale FROM t_wgs;
----
10000000

# UTM CRS → scale 100
statement ok
CREATE TABLE t_utm AS SELECT ST_SetCRS(ST_GeomFromText('POINT(500000 4500000)'), 'EPSG:32618') AS geom;

query I
SELECT (geosilo_metadata(geosilo_encode(geom))).scale FROM t_utm;
----
100

# UTM roundtrip — auto-detected scale
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(geom))) FROM t_utm;
----
POINT (500000 4500000)

# No CRS → default scale 1e7
query I
SELECT (geosilo_metadata(geosilo_encode(ST_GeomFromText('POINT(1 2)')))).scale;
----
10000000

# ---------------------------------------------------------------------------
# Explicit scale overrides CRS
# ---------------------------------------------------------------------------

# Explicit scale 30 (US survey feet)
query I
SELECT (geosilo_metadata(geosilo_encode(ST_GeomFromText('POINT(1000000 500000)'), 30))).scale;
----
30

# Explicit scale roundtrip
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT(500000 4500000)'), 100)));
----
POINT (500000 4500000)

# Different scales produce different quantization
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT(1.23456789 2.34567891)'), 100)))
    != ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT(1.23456789 2.34567891)'), 10000000)));
----
true

# ---------------------------------------------------------------------------
# Compact point encoding
# ---------------------------------------------------------------------------

# POINT XY with default scale (1e7) → compact format: 1 magic + 4+4 coords = 9 bytes
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText('POINT(-77.0364 38.8977)')));
----
9

# POINT XY with scale 100 → compact format: 9 bytes
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText('POINT(500000 4500000)'), 100));
----
9

# POINT XY with non-standard scale → full header: 12 + 8 = 20 bytes
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText('POINT(1.0 2.0)'), 1000));
----
20

# Compact point roundtrip (scale 1e7)
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT(-77.0364 38.8977)'))));
----
POINT (-77.0364 38.8977)

# Compact point roundtrip (scale 100)
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT(500000 4500000)'), 100)));
----
POINT (500000 4500000)

# Compact point metadata
query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('POINT(-77.0364 38.8977)'))) AS m);
----
POINT	XY	10000000

# Compact point metadata (scale 100)
query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('POINT(500000 4500000)'), 100)) AS m);
----
POINT	XY	100

# Empty compact point roundtrip
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT EMPTY'))));
----
POINT EMPTY

# Empty compact point size
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText('POINT EMPTY')));
----
9

# LINESTRING still uses full header (not compact)
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText('LINESTRING(0 0, 1 1)'))) > 12;
----
true

# Batch of compact points roundtrips correctly
query I
SELECT count(*) FROM (
    SELECT i, ST_AsText(geosilo_decode(geosilo_encode(
        ST_Point(i * 0.001 - 77.0, i * 0.001 + 38.0)))) AS txt
    FROM range(1000) t(i)
) WHERE txt IS NOT NULL;
----
1000

# ---------------------------------------------------------------------------
# MULTIPOINT delta encoding (v2)
# ---------------------------------------------------------------------------

# Basic MULTIPOINT roundtrip
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTIPOINT(1 2, 3 4, 5 6)'))));
----
MULTIPOINT (1 2, 3 4, 5 6)

# Empty MULTIPOINT roundtrip
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTIPOINT EMPTY'))));
----
MULTIPOINT EMPTY

# MULTIPOINT metadata reports version correctly
query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('MULTIPOINT(1 2, 3 4)'))) AS m);
----
MULTIPOINT	XY	10000000

# MULTIPOINT with clustered points benefits from delta encoding.
# 10 nearby points: v2 delta should be smaller than 10 absolute points.
# Absolute would be: 12 header + 4 count + 10 * 8 = 96 bytes.
# Delta: 12 header + 4 count + 8 first + 9 * 4 deltas = 60 bytes (if all int16).
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText(
    'MULTIPOINT(-77.0 38.0, -77.001 38.001, -77.002 38.002, -77.003 38.003, -77.004 38.004, -77.005 38.005, -77.006 38.006, -77.007 38.007, -77.008 38.008, -77.009 38.009)'
))) < 96;
----
true

# Large batch of MULTIPOINT roundtrips
query I
SELECT count(*) FROM (
    SELECT ST_AsText(geosilo_decode(geosilo_encode(
        ST_Multi(ST_Union(ST_Point(i * 0.001 - 77.0, i * 0.001 + 38.0),
                          ST_Point(i * 0.001 - 76.5, i * 0.001 + 38.5)))
    ))) AS txt
    FROM range(500) t(i)
) WHERE txt IS NOT NULL;
----
500

# MULTIPOINT with large delta (escape path)
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTIPOINT(0 0, 100 100)'))));
----
MULTIPOINT (0 0, 100 100)

# ---------------------------------------------------------------------------
# Compact headers for all geometry types
# ---------------------------------------------------------------------------

# LINESTRING compact header: 1 byte vs 12-byte full header
# 1 header + 4 count + 8 first_vertex + 12 delta (escape both dims) = 25
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText('LINESTRING(0 0, 1 1)')));
----
25

# POLYGON compact header
query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('POLYGON((0 0, 1 0, 1 1, 0 0))'))) AS m);
----
POLYGON	XY	10000000

# MULTIPOLYGON compact header
query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('MULTIPOLYGON(((0 0, 1 0, 1 1, 0 0)))'))) AS m);
----
MULTIPOLYGON	XY	10000000

# MULTILINESTRING compact header roundtrip
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTILINESTRING((0 0, 1 1), (2 2, 3 3))'))));
----
MULTILINESTRING ((0 0, 1 1), (2 2, 3 3))

# Non-standard scale falls back to full header (12 bytes)
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText('LINESTRING(0 0, 1 1)'), 500));
----
28

# ---------------------------------------------------------------------------
# Ring closure elimination
# ---------------------------------------------------------------------------

# Polygon ring: closure vertex omitted saves bytes.
# POLYGON((0 0, 10 0, 10 10, 0 10, 0 0)) has 5 WKB points (4 + closure).
# With closure elimination, stored count is 4 not 5.
# At scale 1e7, 10 degree deltas escape (100M > int16), so each delta pair = 8 bytes.
# Compact(1) + num_rings(4) + count(4) + first(8) + 3 escaped deltas(24) = 41
# Without closure elimination it would be 49 (one more 8-byte escaped delta pair).
query I
SELECT octet_length(geosilo_encode(ST_GeomFromText('POLYGON((0 0, 10 0, 10 10, 0 10, 0 0))')));
----
41

# Polygon roundtrip preserves the closing vertex in output WKB
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POLYGON((0 0, 10 0, 10 10, 0 10, 0 0))'))));
----
POLYGON ((0 0, 10 0, 10 10, 0 10, 0 0))

# Polygon with hole: both rings get closure elimination
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText(
    'POLYGON((0 0, 100 0, 100 100, 0 100, 0 0), (10 10, 20 10, 20 20, 10 20, 10 10))'))));
----
POLYGON ((0 0, 100 0, 100 100, 0 100, 0 0), (10 10, 20 10, 20 20, 10 20, 10 10))

# MULTIPOLYGON roundtrip with closure elimination
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText(
    'MULTIPOLYGON(((0 0, 1 0, 1 1, 0 0)), ((10 10, 11 10, 11 11, 10 10)))'))));
----
MULTIPOLYGON (((0 0, 1 0, 1 1, 0 0)), ((10 10, 11 10, 11 11, 10 10)))

# Triangle (minimum valid ring: 4 points including closure → stored as 3)
query I
SELECT ST_NPoints(geosilo_decode(geosilo_encode(ST_GeomFromText('POLYGON((0 0, 1 0, 0 1, 0 0))'))));
----
4

# Batch polygon roundtrip
query I
SELECT count(*) FROM (
    SELECT geosilo_decode(geosilo_encode(
        ST_GeomFromText('POLYGON((' || (i*0.01) || ' ' || (i*0.01) || ', ' || (i*0.01+1) || ' ' || (i*0.01) || ', ' || (i*0.01+1) || ' ' || (i*0.01+1) || ', ' || (i*0.01) || ' ' || (i*0.01+1) || ', ' || (i*0.01) || ' ' || (i*0.01) || '))')
    )) AS decoded
    FROM range(1000) t(i)
) WHERE ST_NPoints(decoded) = 5;
----
1000
