# name: test/sql/geosilo.test
# description: test geosilo extension
# group: [geosilo]

require geosilo

statement ok
INSTALL spatial;

statement ok
LOAD spatial;

# ---------------------------------------------------------------------------
# Basic roundtrip — every geometry type
# ---------------------------------------------------------------------------

# Point (use integer coords to avoid float quantization noise in ST_AsText)
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT(-75 40)'))));
----
POINT (-75 40)

# LineString
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('LINESTRING(0 0, 1 1, 2 0)'))));
----
LINESTRING (0 0, 1 1, 2 0)

# Polygon
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POLYGON((0 0, 10 0, 10 10, 0 10, 0 0))'))));
----
POLYGON ((0 0, 10 0, 10 10, 0 10, 0 0))

# Polygon with hole
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POLYGON((0 0, 10 0, 10 10, 0 10, 0 0), (2 2, 8 2, 8 8, 2 8, 2 2))'))));
----
POLYGON ((0 0, 10 0, 10 10, 0 10, 0 0), (2 2, 8 2, 8 8, 2 8, 2 2))

# MultiPoint
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTIPOINT(0 0, 1 1, 2 2)'))));
----
MULTIPOINT (0 0, 1 1, 2 2)

# MultiLineString
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTILINESTRING((0 0, 1 1), (2 2, 3 3))'))));
----
MULTILINESTRING ((0 0, 1 1), (2 2, 3 3))

# MultiPolygon
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTIPOLYGON(((0 0, 1 0, 1 1, 0 1, 0 0)), ((2 2, 3 2, 3 3, 2 3, 2 2)))'))));
----
MULTIPOLYGON (((0 0, 1 0, 1 1, 0 1, 0 0)), ((2 2, 3 2, 3 3, 2 3, 2 2)))

# GeometryCollection
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('GEOMETRYCOLLECTION(POINT(0 0), LINESTRING(1 1, 2 2))'))));
----
GEOMETRYCOLLECTION (POINT (0 0), LINESTRING (1 1, 2 2))

# ---------------------------------------------------------------------------
# Empty geometries
# ---------------------------------------------------------------------------

query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT EMPTY'))));
----
POINT EMPTY

query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('LINESTRING EMPTY'))));
----
LINESTRING EMPTY

query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POLYGON EMPTY'))));
----
POLYGON EMPTY

query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('MULTIPOLYGON EMPTY'))));
----
MULTIPOLYGON EMPTY

# ---------------------------------------------------------------------------
# NULL handling
# ---------------------------------------------------------------------------

query I
SELECT geosilo_encode(NULL::GEOMETRY);
----
NULL

query I
SELECT geosilo_decode(NULL::BLOB);
----
NULL

# ---------------------------------------------------------------------------
# Custom scale
# ---------------------------------------------------------------------------

# Roundtrip with custom scale (projected CRS in meters)
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT(500000 4500000)'), 100)));
----
POINT (500000 4500000)

# Different scales produce different blobs
query I
SELECT geosilo_encode(ST_GeomFromText('POINT(1 1)'), 100) != geosilo_encode(ST_GeomFromText('POINT(1 1)'), 10000000);
----
true

# ---------------------------------------------------------------------------
# Size reduction
# ---------------------------------------------------------------------------

# Silo blob should be smaller than WKB for polygons
query I
SELECT octet_length(geosilo_encode(geom)) < octet_length(ST_AsWKB(geom))
FROM (SELECT ST_GeomFromText('POLYGON((0 0, 10 0, 10 10, 0 10, 0 0))') AS geom);
----
true

# ---------------------------------------------------------------------------
# Overflow protection
# ---------------------------------------------------------------------------

# Coordinate that overflows int32 at default scale 1e7 should error
statement error
SELECT geosilo_encode(ST_GeomFromText('POINT(300 0)'));
----
GeoSilo: coordinate 300.0000000 overflows int32 at scale 10000000

# Same coordinate works with a smaller scale
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('POINT(300 0)'), 100)));
----
POINT (300 0)

# ---------------------------------------------------------------------------
# Large delta (int16 escape to int32)
# ---------------------------------------------------------------------------

# Two points far apart — delta won't fit int16, uses escape path
query I
SELECT ST_AsText(geosilo_decode(geosilo_encode(ST_GeomFromText('LINESTRING(-180 -90, 180 90)'))));
----
LINESTRING (-180 -90, 180 90)

# ---------------------------------------------------------------------------
# Mixed geometry types in a column
# ---------------------------------------------------------------------------

query I
SELECT count(*) FROM (
    SELECT geosilo_decode(geosilo_encode(geom)) AS decoded FROM (
        VALUES
            (ST_GeomFromText('POINT(0 0)')),
            (ST_GeomFromText('LINESTRING(0 0, 1 1)')),
            (ST_GeomFromText('POLYGON((0 0, 1 0, 1 1, 0 0))')),
            (ST_GeomFromText('MULTIPOINT(0 0, 1 1)')),
            (ST_GeomFromText('MULTIPOLYGON(((0 0, 1 0, 1 1, 0 0)))'))
    ) AS t(geom)
    WHERE ST_GeometryType(geosilo_decode(geosilo_encode(geom))) = ST_GeometryType(geom)
);
----
5

# ---------------------------------------------------------------------------
# geosilo_metadata
# ---------------------------------------------------------------------------

query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('POINT(1 2)'))) AS m);
----
POINT	XY	10000000

query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('MULTIPOLYGON(((0 0, 1 0, 1 1, 0 0)))'))) AS m);
----
MULTIPOLYGON	XY	10000000

query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('LINESTRING(0 0, 1 1)'), 100)) AS m);
----
LINESTRING	XY	100

query I
SELECT geosilo_metadata(NULL::BLOB);
----
NULL

# ---------------------------------------------------------------------------
# geosilo_metadata — all geometry types
# ---------------------------------------------------------------------------

query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('LINESTRING EMPTY'))) AS m);
----
LINESTRING	XY	10000000

query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('POLYGON((0 0, 1 0, 1 1, 0 0))'))) AS m);
----
POLYGON	XY	10000000

query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('MULTIPOINT(0 0, 1 1)'))) AS m);
----
MULTIPOINT	XY	10000000

query III
SELECT m.geometry_type, m.vertex_type, m.scale
FROM (SELECT geosilo_metadata(geosilo_encode(ST_GeomFromText('MULTILINESTRING((0 0, 1 1), (2 2, 3 3))'))) AS m);
----
